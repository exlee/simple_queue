{
  "db_name": "PostgreSQL",
  "query": "\n        UPDATE job_queue\n        SET\n            status = $2,\n            attempt = attempt + 1\n\n        WHERE id = (\n            SELECT id FROM job_queue\n            WHERE status = $1\n            AND (NOW() > run_at OR run_at IS NULL)\n            AND attempt < max_attempts\n            FOR UPDATE SKIP LOCKED\n            LIMIT 1\n        )\n        RETURNING *\n        ",
